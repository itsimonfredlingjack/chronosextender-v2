{
  "name": "chronosextender",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:${CHRONOS_RENDERER_PORT:-5183} && electron .",
    "apps:dev": "node server.js",
    "apps:inspect": "npx @modelcontextprotocol/inspector@latest --server-url http://localhost:8787/mcp --transport http",
    "build": "vite build",
    "test": "vitest run",
    "test:ui-quality": "vitest run src/renderer/__tests__/ui-regression-snapshots.test.tsx src/renderer/__tests__/design-token-guard.test.ts src/renderer/__tests__/renderer-integration.test.tsx src/renderer/__tests__/theme-tokens.test.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "framer-motion": "^12.35.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.3.1",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.3",
    "vite": "^7.1.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.3"
  }
}
